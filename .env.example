# Copy to .env.local and adjust. All values are optional — with nothing set, the
# app runs fully mocked (simulated provisioning + placeholder Playground answers).

# --- Playground inference backend ---------------------------------------------
# (unset) = mock placeholder | ollama = free local model | vultr = Vultr Serverless
ACRE_INFERENCE=

# Ollama (local, free). Pull a model first, e.g.  ollama pull llama3.2:3b
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b

# Vultr Serverless Inference (for the deployed demo). Key from the Vultr portal's
# Serverless Inference product (NOT the main account API key).
# Model list changes over time — check GET /v1/models and set accordingly.
# VULTR_INFERENCE_API_KEY=
# VULTR_INFERENCE_MODEL=deepseek-ai/DeepSeek-V4-Flash

# --- Provisioning backend -----------------------------------------------------
# (unset) = simulated MockProvisioner. The real Vultr adapter is still a stub.
# ACRE_PROVISIONER=
# VULTR_API_KEY=

# Every region provisions by default. To demo the capacity-failure/retry flow,
# list region codes that should fail (comma-separated), e.g. blr for Bangalore:
# ACRE_CAPACITY_REGIONS=blr
